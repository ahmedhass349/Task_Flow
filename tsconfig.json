{
    "compilerOptions": {
        "outDir": "./dist/",
        "sourceMap": true,
        "noImplicitAny": false,
        "module": "ESNext",
        "moduleResolution": "node",
        "target": "ES6",
        "jsx": "react-jsx",
        "lib": ["ES6", "dom", "ES2021"],
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true
    },
    "include": [
        "./ReactApp/**/*"
    ],
    "exclude": [
        "./ReactApp/Containers/**/*",
        "./ReactApp/scss/**/*"
    ]
}