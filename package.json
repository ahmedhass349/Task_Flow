{
  "name": "taskflow",
  "version": "0.0.1-alpha",
  "description": "taskflow template project",
  "main": "public/electron.js",
  "homepage": "https://github.com/Ahmed-Abdelbarr/Task_Flow#readme",
  "scripts": {
    "build:dev": "webpack --progress",
    "build": "cross-env NODE_ENV=production webpack --env prod --progress",
    "build:web": "cross-env NODE_ENV=production webpack --env prod --progress",
    "publish:backend": "dotnet publish TaskFlow.csproj -c Release -o publish/backend --nologo -r win-x64 --self-contained true /p:PublishSingleFile=true /p:IncludeNativeLibrariesForSelfExtract=true",
    "start": "webpack serve --open",
    "dev:web": "concurrently \"dotnet run --project TaskFlow.csproj\" \"webpack --progress --watch\"",
    "dev:electron": "concurrently \"webpack serve --port 3000 --no-open\" \"wait-on http://localhost:3000 && cross-env ELECTRON_IS_DEV=true electron .\"",
    "electron-dev": "cross-env ELECTRON_IS_DEV=true electron .",
    "preelectron-dev": "npm run build:dev",
    "preelectron-build": "npm run build:web && npm run publish:backend",
    "electron-build": "electron-builder --config electron-builder.json",
    "test:phase4": "python phase4_test.py",
    "test:phase5": "python phase5_test.py",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "files": [
    "dist"
  ],
  "typings": "./dist/types/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ahmed-Abdelbarr/Task_Flow.git"
  },
  "keywords": [
    "dotnet",
    "core",
    "taskflow"
  ],
  "author": "Ahmed Abdelbarr",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Ahmed-Abdelbarr/Task_Flow/issues"
  },
  "dependencies": {
    "@microsoft/signalr": "^10.0.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router": "^7.14.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webpack-env": "^1.18.8",
    "autoprefixer": "^10.5.0",
    "compression-webpack-plugin": "^12.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.4",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "mini-css-extract-plugin": "^2.9.0",
    "postcss-loader": "^8.2.1",
    "sass": "^1.77.0",
    "sass-loader": "^16.0.5",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.2.4",
    "ts-loader": "^9.5.1",
    "typescript": "^6.0.3",
    "wait-on": "^8.0.1",
    "webpack": "^5.105.4",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.3"
  }
}
